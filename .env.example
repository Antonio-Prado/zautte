# ============================================================
# Zautte — file di configurazione ambiente
# Copia questo file in .env e compila i valori
# ============================================================

# --- Sito da indicizzare (OBBLIGATORI) ---
SITE_URL=https://www.tuo-sito.it
SITE_NAME=Nome del tuo ente o organizzazione

# Domini consentiti nel crawl (separati da virgola)
# Includi il dominio principale e tutti i sottodomini da indicizzare
CRAWL_ALLOWED_DOMAINS=www.tuo-sito.it

# --- LLM provider: "ollama" (locale) oppure "claude" (API Anthropic) ---
LLM_PROVIDER=ollama

# Ollama (locale, privacy totale)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Claude API (Anthropic) — usare se LLM_PROVIDER=claude
# Richiede account Anthropic e, per enti pubblici, verifica dei requisiti normativi
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Backend API ---
API_HOST=127.0.0.1
API_PORT=8000
# Dominio/i del sito su cui viene embeddato il widget (per CORS)
API_CORS_ORIGINS=https://www.tuo-sito.it

# --- Autenticazione endpoint admin (/stats, /gaps, /feedback/list) ---
# Lasciare vuoto per disabilitare l'autenticazione (SOLO in sviluppo)
ADMIN_API_KEY=cambia-questa-chiave-in-produzione
